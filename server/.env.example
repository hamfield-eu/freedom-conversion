# ---- Server ----
# All settings are optional; these are the defaults. No API key is required —
# the Frankfurter exchange-rate API is free and keyless.

PORT=8081

# How long (seconds) to cache a fetched rate before calling Frankfurter again.
RATE_CACHE_TTL=3600

# Frankfurter API base URL. Override only if you self-host Frankfurter.
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1
